### API Client (Functional Approach)
```typescript
// app/services/api/apiClient.ts
export const fetchFromApi = async <T>(
  endpoint: string, 
  params?: Record<string, string>
): Promise<T> => {
  try {
    const urlParams = params ? new URLSearchParams(params).toString() : '';
    const url = `${endpoint}${urlParams ? `?${urlParams}` : ''}`;
    const response = await fetch(url);
    
    if (!response.ok) {
      throw new Error(`API error: ${response.status}`);
    }
    
    return await response.json();
  } catch (error) {
    // Error handling with proper logging
    console.error(`API error for ${endpoint}:`, error);
    throw error;
  }
};

// With retry logic
export const fetchWithRetry = <T>(
  endpoint: string,
  params?: Record<string, string>,
  retries = 3,
  delay = 300
): Promise<T> => {
  return fetchFromApi<T>(endpoint, params).catch(error => {
    if (retries <= 0) throw error;
    return new Promise(resolve => setTimeout(resolve, delay))
      .then(() => fetchWithRetry(endpoint, params, retries - 1, delay * 2));
  });
};
```

Data fetching uses React Router loaders and useFetcher (api-request-pattern.mdc).

### State Management (Functional)
Store only data; export actions as standalone functions so components can avoid subscribing for action references.

```typescript
// app/stores/tariffStore.ts
interface TariffState {
  readonly tariffs: readonly Tariff[];
}

export const useTariffStore = create<TariffState>(() => ({
  tariffs: [],
}));

export const setTariffsInStore = (tariffs: readonly Tariff[]): void => {
  useTariffStore.setState({ tariffs });
};

export const sortTariffsInStore = (field: keyof Tariff): void => {
  useTariffStore.setState((state) => ({
    tariffs: [...state.tariffs].sort((a, b) => a[field] - b[field]),
  }));
};

export const useSortedTariffs = (sortField: keyof Tariff) =>
  useTariffStore(
    (state) => [...state.tariffs].sort((a, b) => a[sortField] - b[sortField]),
    shallow,
  );
```

### Store Initial Data (Hydration)
For one-off initialization from loader/API result, export a pure function that calls `store.setState()` so callers do not need to subscribe to the store. Use from orchestrating hooks (e.g. `useSetInitialData`) by calling the function directly.

```typescript
// store: export pure setter, no hook
export const setInitialToastInfo = (result: ResultDTO): void => {
  const { toastInfos } = result;
  if (!isDefined(toastInfos)) {
    useToastInfoStore.setState({ data: null });
    return;
  }
  useToastInfoStore.setState({ data: toastInfos });
};

// orchestrating hook: call pure setters directly; use hooks only for setters that need hook context
function applyResultToStores(result: ResultDTO, setters: Setters): void {
  setInitialToastInfo(result);
  setInitialProvidersData(result.providerList, result.referenceTariff?.providerHash, ...);
  if (isDefined(result.debug)) setDebugMenuData(result.debug);
  setters.setInitialHintListData(result);
}
```

### Functional Composition Example
```typescript
// Function composition utilities
const pipe = <T>(...fns: Array<(arg: T) => T>) => 
  (value: T): T => fns.reduce((acc, fn) => fn(acc), value);

// Tariff formatting functions
const addCurrencySymbol = (price: number): string => `${price} €`;
const formatToTwoDecimals = (price: number): number => Math.round(price * 100) / 100;
const applyDiscount = (discount: number) => (price: number): number => price * (1 - discount);

// Usage
const formatPrice = (price: number, discount: number): string => 
  pipe(
    applyDiscount(discount),
    formatToTwoDecimals,
    addCurrencySymbol
  )(price);

// In component
function TariffPrice({ tariff, discount }) {
  const formattedPrice = useMemo(
    () => formatPrice(tariff.price, discount),
    [tariff.price, discount]
  );
  
  return <div>{formattedPrice}</div>;
}
```

