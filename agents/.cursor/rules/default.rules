prefix_rule(pattern=["node", "-e", "const fs=require('fs'); const path=require('path'); const dir=path.join(process.cwd(),'wishees-qa-campaign-20260605'); const eventsPath=path.join(dir,'events.jsonl'); const statePath=path.join(dir,'state.json'); const bugsPath=path.join(dir,'bugs.json'); const st=JSON.parse(fs.readFileSync(statePath,'utf8')); const ts=()=>new Date().toISOString(); async function main(){const started=Date.now(); let response=null,text='',json=null,error=null; try{response=await fetch('https://www.wishees.com/api/auth/login',{method:'POST',headers:{'content-type':'application/json','accept':'application/json','origin':'https://www.wishees.com','referer':'https://www.wishees.com/account/login'},body:JSON.stringify({email:'test-partner@wishees.local',accessCode:'',next:'/profile?lang=de'}),signal:AbortSignal.timeout(20000)}); text=await response.text(); try{json=JSON.parse(text)}catch{}}catch(e){error=e instanceof Error?e.name+': '+e.message:String(e)} const event={ts:ts(),runId:st.runId,session:'partner-blank-access-code',feature:'auth',action:'partner login blank access code probe',request:{method:'POST',route:'/api/auth/login',body:JSON.stringify({email:'test-partner@wishees.local',accessCode:'',next:'/profile?lang=de'})},response:response?{status:response.status,ok:response.ok,contentType:response.headers.get('content-type')||'',body:JSON.stringify(json??text).slice(0,3000)}:null,durationMs:Date.now()-started,error}; fs.appendFileSync(eventsPath,JSON.stringify(event)+'\\n'); st.coverage['auth.partner-login.blank-access-code']=st.coverage['auth.partner-login.blank-access-code']||{count:0}; st.coverage['auth.partner-login.blank-access-code'].count+=1; st.coverage['auth.partner-login.blank-access-code'].lastAt=ts(); st.coverage['auth.partner-login.blank-access-code'].lastDetail={status:response&&response.status,body:json,error,classification:json&&json.ok?'accepted':'credential-missing-or-invalid'}; st.updatedAt=ts(); st.notes=st.notes||[]; st.notes.push({ts:ts(),type:'credential-gap',message:'Partner profile test-partner@wishees.local was supplied without an access code/password; blank access-code login probe did not provide a usable authenticated session unless body.ok=true.',result:json??error}); fs.writeFileSync(statePath,JSON.stringify(st,null,2)+'\\n'); console.log(JSON.stringify({status:response&&response.status,body:json,error,classification:st.coverage['auth.partner-login.blank-access-code'].lastDetail.classification},null,2));} main();"], decision="allow")
prefix_rule(pattern=["node", "-e", "const fs=require('fs');const path=require('path');const dir=path.join(process.cwd(),'wishees-qa-campaign-20260605');const eventsPath=path.join(dir,'events.jsonl');const statePath=path.join(dir,'state.json');const bugsPath=path.join(dir,'bugs.json');const telPath=path.join(dir,'telemetry.jsonl');const st=JSON.parse(fs.readFileSync(statePath,'utf8'));const bugs=JSON.parse(fs.readFileSync(bugsPath,'utf8'));const ts=()=>new Date().toISOString();const started=Date.now();(async()=>{let response=null,text='',json=null,error=null;try{response=await fetch('https://www.wishees.com/api/auth/login',{method:'POST',headers:{'content-type':'application/json','accept':'application/json','origin':'https://www.wishees.com','referer':'https://www.wishees.com/account/login'},body:JSON.stringify({email:'test-partner@wishees.local',accessCode:'',next:'/profile?lang=de'}),signal:AbortSignal.timeout(20000)});text=await response.text();try{json=JSON.parse(text)}catch{}}catch(e){error=e instanceof Error?e.name+': '+e.message:String(e)}const event={ts:ts(),runId:st.runId,session:'partner-blank-access-code',feature:'auth',action:'partner login blank access code probe',request:{method:'POST',route:'/api/auth/login',body:JSON.stringify({email:'test-partner@wishees.local',accessCode:'',next:'/profile?lang=de'})},response:response?{status:response.status,ok:response.ok,contentType:response.headers.get('content-type')||'',body:JSON.stringify(json??text).slice(0,3000)}:null,durationMs:Date.now()-started,error};fs.appendFileSync(eventsPath,JSON.stringify(event)+'\\n');st.coverage['auth.partner-login.blank-access-code']=st.coverage['auth.partner-login.blank-access-code']||{count:0};st.coverage['auth.partner-login.blank-access-code'].count+=1;st.coverage['auth.partner-login.blank-access-code'].lastAt=ts();st.coverage['auth.partner-login.blank-access-code'].lastDetail={status:response&&response.status,body:json,error,classification:json&&json.ok?'accepted':'credential-missing-or-invalid'};st.updatedAt=ts();st.notes=st.notes||[];st.notes.push({ts:ts(),type:'credential-gap',message:'Partner profile test-partner@wishees.local was supplied without an access code/password; blank access-code login probe did not provide a usable authenticated session unless body.ok=true.',result:json??error});fs.writeFileSync(statePath,JSON.stringify(st,null,2)+'\\n');const telemetry={elapsedTime:'00:00:'+String(Math.floor((Date.now()-started)/1000)).padStart(2,'0'),currentUserSession:'partner-blank-access-code',coveragePercentage:'100%',activeWorkflow:'partner credential boundary probe completed',identifiedBugs:bugs.map(b=>({severity:b.severity,stepsToReproduce:b.stepsToReproduce||b.steps||[],actualBehavior:b.actualBehavior||''}))};fs.appendFileSync(telPath,JSON.stringify(telemetry)+'\\n');console.log(JSON.stringify({status:response&&response.status,body:json,error,classification:st.coverage['auth.partner-login.blank-access-code'].lastDetail.classification},null,2));})().catch(e=>{console.error(e);process.exit(1)});"], decision="allow")
